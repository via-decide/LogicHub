{
  "$ref": "#/definitions/ValidationResult",
  "definitions": {
    "ValidationResult": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "default": "0.1.0"
        },
        "projectId": {
          "type": "string",
          "minLength": 1
        },
        "revisionId": {
          "type": "string",
          "minLength": 1
        },
        "changeIntentId": {
          "type": "string",
          "minLength": 1
        },
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "validatorVersion": {
          "type": "string",
          "minLength": 1
        },
        "validationType": {
          "type": "string",
          "enum": [
            "schema",
            "repository_integrity",
            "kicad_import",
            "erc",
            "drc",
            "bom",
            "constraint",
            "artifact_integrity",
            "merge_gate"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warning",
            "fail",
            "error",
            "unknown",
            "skipped"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": {
                "type": "string",
                "enum": [
                  "error",
                  "warning",
                  "info",
                  "hint"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "location": {},
              "code": {
                "type": "string"
              }
            },
            "required": [
              "severity",
              "message"
            ],
            "additionalProperties": false
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "inputHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "projectId",
        "revisionId",
        "validator",
        "validatorVersion",
        "validationType",
        "status",
        "startedAt",
        "diagnostics",
        "artifactIds",
        "createdAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
