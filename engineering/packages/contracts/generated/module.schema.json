{
  "$ref": "#/definitions/Module",
  "definitions": {
    "Module": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "default": "0.1.0"
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "sourceProjectId": {
          "type": "string",
          "minLength": 1
        },
        "sourceRevisionId": {
          "type": "string",
          "minLength": 1
        },
        "interfaces": {
          "type": "array",
          "items": {}
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints": {
          "type": "array",
          "items": {}
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "moduleId": {
                "type": "string",
                "minLength": 1
              },
              "versionConstraint": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "moduleId",
              "versionConstraint"
            ],
            "additionalProperties": false
          }
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "bomItemIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verificationStatus": {
          "type": "string",
          "enum": [
            "unverified",
            "community",
            "reviewed",
            "validated",
            "deprecated",
            "revoked"
          ],
          "default": "unverified"
        },
        "license": {
          "type": "string"
        },
        "maintainers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "namespace",
        "name",
        "version",
        "interfaces",
        "requirements",
        "constraints",
        "dependencies",
        "artifactIds",
        "bomItemIds",
        "maintainers",
        "createdAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
