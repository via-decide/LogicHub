{
  "$ref": "#/definitions/Decision",
  "definitions": {
    "Decision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "default": "0.1.0"
        },
        "projectId": {
          "type": "string",
          "minLength": 1
        },
        "revisionId": {
          "type": "string",
          "minLength": 1
        },
        "changeIntentId": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string"
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "tradeoffs": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "description"
            ],
            "additionalProperties": false
          }
        },
        "selectedAlternative": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "tradeoffs": {
          "type": "string"
        },
        "constraintsConsidered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidenceArtifactIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validationResultIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "rejected",
            "superseded"
          ],
          "default": "proposed"
        },
        "createdBy": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "supersedesDecisionId": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "projectId",
        "revisionId",
        "question",
        "alternatives",
        "constraintsConsidered",
        "evidenceArtifactIds",
        "validationResultIds",
        "createdBy",
        "createdAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
