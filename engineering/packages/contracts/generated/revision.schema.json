{
  "$ref": "#/definitions/Revision",
  "definitions": {
    "Revision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "default": "0.1.0"
        },
        "projectId": {
          "type": "string",
          "minLength": 1
        },
        "gitCommitSha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "branchName": {
          "type": "string",
          "minLength": 1
        },
        "parentRevisionIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "snapshotHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "engineeringObjectSnapshotHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "constraintSnapshotHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "decisionSnapshotHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bomSnapshotHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifactManifestHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "toolchain": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "imported",
            "validating",
            "validated",
            "review",
            "merged",
            "rejected",
            "failed"
          ],
          "default": "draft"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "projectId",
        "gitCommitSha",
        "branchName",
        "parentRevisionIds",
        "author",
        "message",
        "createdAt",
        "toolchain"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
