{
  "$ref": "#/definitions/Project",
  "definitions": {
    "Project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "default": "0.1.0"
        },
        "slug": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "description": {
          "type": "string"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "organization"
          ]
        },
        "repository": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "minLength": 1
            },
            "remoteUrl": {
              "type": "string",
              "format": "uri"
            },
            "localPath": {
              "type": "string",
              "minLength": 1
            },
            "defaultBranch": {
              "type": "string",
              "default": "main"
            }
          },
          "required": [
            "provider",
            "localPath"
          ],
          "additionalProperties": false
        },
        "defaultBranch": {
          "type": "string",
          "default": "main"
        },
        "createdBy": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "suspended"
          ],
          "default": "active"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "slug",
        "name",
        "visibility",
        "repository",
        "createdBy",
        "createdAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
