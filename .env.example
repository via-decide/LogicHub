# -------- Client (browser) --------
# Used by static deployment health checks when validating API reachability.
# Example: https://your-app.vercel.app
PUBLIC_SITE_URL=

# Optional client-side endpoint override for fetch('/api/...') paths.
# Leave empty to use same-origin /api routes.
PUBLIC_API_BASE_URL=

# Execution engine used by publish synthesis endpoint.
# Current server route uses gemini-1.5-flash.
EXECUTION_ENGINE=gemini-1.5-flash

# -------- Serverless API --------
# GitHub integration (api/publish-app.js + api/publish/index.js)
GITHUB_TOKEN=
GITHUB_OWNER=via-decide
GITHUB_REPO=
GITHUB_BRANCH=main

# Firebase admin (api/_firebaseAdmin.js)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=
FIREBASE_ADMIN_SECRET=

# Founder request notifications (api/founder-request.js)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FROM_EMAIL=

# APK build pipeline (api/build-apk.js)
APK_SHELL_DIR=

# AI synthesis endpoint (api/publish/index.js)
GEMINI_API_KEY=
