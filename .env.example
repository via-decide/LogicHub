# ---------- Runtime ----------
# Public site URL used by deploy checks and canonical links.
SITE_URL=https://logichub.app

# API base URL for hosted serverless functions.
# Keep blank to use same-origin '/api' in production.
API_BASE_URL=

# UI execution engine.
# Current supported options: gemini
EXECUTION_ENGINE=gemini

# ---------- Serverless API (optional on static-only hosts) ----------
GEMINI_API_KEY=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

APK_SHELL_DIR=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_ADMIN_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
FROM_EMAIL=

# ---------- Browser config (optional) ----------
# If present, expose in HTML as: window.LOGICHUB_API_BASE
LOGICHUB_API_BASE=
