{
  "name": "logichub",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:assets && npm run build:vercel",
    "build:assets": "node ./build/copy-static.js",
    "build:vercel": "npm run build:assets && npm run health-check:build && npm run finalize:build",
    "health-check:build": "node ./deploy/health-check.js --mode=build",
    "finalize:build": "node ./build/finalize.js",
    "recover:deployments": "node ./deploy/recover-deployments.js",
    "dev": "node ./deploy/dev-server.js",
    "start": "node ./api/index.js"
  },
  "dependencies": {
    "firebase-admin": "^13.4.0"
  }
}
